{
  "name": "modern",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "lint": "oxlint --fix --deny-warnings .",
    "format": "concurrently -n fmt,lint 'oxfmt .' 'bun run lint'",
    "check": "concurrently -n fmt,lint,ts 'oxfmt --check .' 'bun run lint' 'bun run --workspaces check'",
    "prepare": "husky"
  },
  "dependencies": {
    "@tauri-apps/plugin-shell": "~2",
    "ai": "^5.0.98"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@typescript/native-preview": "^7.0.0-dev.20260222.1",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "oxfmt": "^0.34.0",
    "oxlint": "^1.49.0"
  },
  "packageManager": "bun@1.3.0",
  "patchedDependencies": {
    "@orpc/tanstack-query@1.11.3": "patches/@orpc%2Ftanstack-query@1.11.3.patch"
  }
}
