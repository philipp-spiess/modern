{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Modern",
  "version": "0.1.0",
  "identifier": "dev.modern",
  "build": {
    "beforeDevCommand": "bun --cwd packages/client dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run --workspaces build",
    "frontendDist": "../packages/client/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Modern",
        "width": 1280,
        "height": 800,
        "minWidth": 400,
        "minHeight": 300,
        "decorations": true,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 20,
          "y": 30
        },
        "dragDropEnabled": false
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "draggable-window",
          "windows": ["*"],
          "permissions": ["core:window:allow-start-dragging", "core:window:allow-internal-toggle-maximize"]
        },
        {
          "identifier": "rpc-events",
          "windows": ["*"],
          "permissions": ["core:event:allow-listen", "core:event:allow-unlisten", "core:event:allow-emit"]
        },
        {
          "identifier": "window-destroy",
          "windows": ["*"],
          "permissions": ["core:window:allow-destroy"]
        },
        {
          "identifier": "file-dialog",
          "windows": ["*"],
          "permissions": ["dialog:allow-open"]
        },
        {
          "identifier": "menu",
          "windows": ["*"],
          "permissions": ["core:menu:default"]
        },
        {
          "identifier": "webview-window",
          "windows": ["*"],
          "permissions": [
            "core:webview:allow-create-webview-window",
            "core:webview:allow-set-webview-size",
            "core:window:allow-set-title",
            "core:window:allow-set-fullscreen",
            "core:window:allow-close",
            "core:window:allow-set-size",
            "core:window:allow-center"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "deb", "rpm", "appimage", "nsis", "msi"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "resources": ["icon-assets/Assets.car", "pi-agent/package.json", "binaries/rg"],
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "externalBin": ["binaries/server"]
  }
}
